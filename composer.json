{
    "name": "componist/reminder-notifications",
    "description": "Livewire-powered reminder notifications for Laravel.",
    "keywords": [
        "laravel",
        "livewire",
        "notifications",
        "reminder",
        "scheduler"
    ],
    "homepage": "",
    "license": "MIT",
    "authors": [
        {
            "name": "Componist Developer",
            "email": "info@componist.dev",
            "role": "Developer"
        }
    ],
    "require": {
        "livewire/livewire": "^4.0"
    },
    "require-dev": {},
    "autoload": {
        "psr-4": {
            "Componist\\ReminderNotifications\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Componist\\ReminderNotifications\\ReminderNotificationsServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}